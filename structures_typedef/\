#include "stdio.h"
#include "dog.h"

/**
* init_dog - initialize a variable of type
*@name: name of the dog
*@age: age of the dog
*@owner: the owner of the dog
*@d: initialising the dog to the pointer
*/
void init_dog(struct dog *d, char *name, float age, char *owner)

{
	if (d != NULL)
	{

		d->name = "name";
		d->age = "age";
		d->owner = "owner";
	}
}

